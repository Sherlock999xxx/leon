{
  "$schema": "../../schemas/skill-schemas/skill.json",
  "name": "Rochambeau",
  "bridge": "python",
  "version": "1.0.0",
  "description": "Rock paper scissors game.",
  "author": {
    "name": "Louis Grenard",
    "email": "louis@getleon.ai",
    "url": "https://github.com/louistiti"
  },
  "actions": {
    "set_up": {
      "type": "dialog",
      "description": "Set up the game by asking the owner to choose rock, paper or scissors.",
      "next_action": "play"
    },
    "play": {
      "type": "logic",
      "description": "Play the game by choosing rock, paper or scissors.",
      "parameters": {
        "handsign": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ROCK", "PAPER", "SCISSORS"],
              "description": "The hand sign chosen by the owner."
            }
          }
        }
      },
      "is_loop": true,
      "next_action": "rematch"
    },
    "rematch": {
      "type": "logic",
      "description": "Ask the owner if they want to play again.",
      "parameters": {
        "confirmation": {
          "type": "boolean",
          "description": "Whether the owner wants to play again or not."
        }
      },
      "is_loop": true,
      "suggestions": ["%REMATCH_YES%", "%REMATCH_NO%"]
    }
  }
}
